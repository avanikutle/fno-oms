<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0"
         metadata-complete="true">

    <display-name>FnO Order Management System</display-name>
    <description>Options trading OMS — mStock broker integration, Java 25, Tomcat 11</description>

    <!-- ========== Session Configuration ========== -->
    <session-config>
        <session-timeout>60</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
        </cookie-config>
    </session-config>

    <!-- ========== Startup Listener ========== -->
    <listener>
        <listener-class>com.fnooms.servlet.AppStartupListener</listener-class>
    </listener>

    <!-- ========== Servlets ========== -->
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.fnooms.servlet.DashboardServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet>
        <servlet-name>OrderServlet</servlet-name>
        <servlet-class>com.fnooms.servlet.OrderServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>QuoteServlet</servlet-name>
        <servlet-class>com.fnooms.servlet.QuoteServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>PortfolioServlet</servlet-name>
        <servlet-class>com.fnooms.servlet.PortfolioServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>BrokerConfigServlet</servlet-name>
        <servlet-class>com.fnooms.servlet.BrokerConfigServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AuthServlet</servlet-name>
        <servlet-class>com.fnooms.servlet.AuthServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ConnectivityServlet</servlet-name>
        <servlet-class>com.fnooms.servlet.ConnectivityServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>InstrumentServlet</servlet-name>
        <servlet-class>com.fnooms.servlet.InstrumentServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SettingsServlet</servlet-name>
        <servlet-class>com.fnooms.servlet.SettingsServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>StrategyServlet</servlet-name>
        <servlet-class>com.fnooms.servlet.StrategyServlet</servlet-class>
    </servlet>

    <!-- ========== Servlet Mappings ========== -->
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>OrderServlet</servlet-name>
        <url-pattern>/api/orders/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>QuoteServlet</servlet-name>
        <url-pattern>/api/quote</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>PortfolioServlet</servlet-name>
        <url-pattern>/api/portfolio/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>BrokerConfigServlet</servlet-name>
        <url-pattern>/api/broker-config/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AuthServlet</servlet-name>
        <url-pattern>/api/auth/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ConnectivityServlet</servlet-name>
        <url-pattern>/api/connectivity/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>InstrumentServlet</servlet-name>
        <url-pattern>/api/instruments/search</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SettingsServlet</servlet-name>
        <url-pattern>/api/settings/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StrategyServlet</servlet-name>
        <url-pattern>/api/strategies/*</url-pattern>
    </servlet-mapping>

    <!-- Static assets served by Tomcat's default servlet -->
    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>/static/*</url-pattern>
    </servlet-mapping>

    <!-- DashboardServlet (mapped to /) handles root — no welcome file needed -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ========== Error Pages ========== -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/jsp/error.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/jsp/error.jsp</location>
    </error-page>

</web-app>
